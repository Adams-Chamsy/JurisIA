# ============================================
# JurisIA — Variables d'Environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ============================================

# ---- APPLICATION ----
APP_NAME=JurisIA
APP_ENV=development         # development | staging | production
APP_SECRET_KEY=             # openssl rand -hex 32 — OBLIGATOIRE
APP_DEBUG=true              # false en production
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- BASE DE DONNÉES PostgreSQL ----
DATABASE_URL=postgresql+asyncpg://jurisai:jurisai_dev_password@localhost:5432/jurisai_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---- REDIS ----
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600        # secondes (1 heure)

# ---- AUTHENTICATION JWT ----
JWT_SECRET_KEY=             # openssl rand -hex 64 — OBLIGATOIRE, différent de APP_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- CHIFFREMENT (données sensibles en BDD) ----
ENCRYPTION_KEY=             # Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---- MISTRAL AI (LLM Souverain FR) ----
MISTRAL_API_KEY=            # https://console.mistral.ai/
MISTRAL_MODEL=mistral-large-latest   # ou mistral-medium pour dev (moins cher)
MISTRAL_MAX_TOKENS=4096
MISTRAL_TEMPERATURE=0.1     # Bas pour le juridique (déterminisme)

# ---- QDRANT (Vector Database) ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=             # Laisser vide en local (pas d'auth), requis en prod
QDRANT_COLLECTION_NAME=jurisai_legal_corpus

# ---- STOCKAGE FICHIERS (OVH Object Storage / S3-compatible) ----
S3_ENDPOINT_URL=            # https://s3.gra.cloud.ovh.net en prod, laisser vide pour MinIO local
S3_ACCESS_KEY_ID=           # Credentials OVH ou MinIO local
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=jurisai-documents
S3_REGION=gra               # Région OVH (gra = Gravelines, FR)

# ---- STRIPE (Paiements) ----
STRIPE_SECRET_KEY=          # sk_test_... en dev, sk_live_... en prod
STRIPE_WEBHOOK_SECRET=      # whsec_... — récupéré après création du webhook Stripe
STRIPE_PRICE_ID_STARTER=    # price_... — créé dans le dashboard Stripe
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# ---- MAILJET (Emails transactionnels) ----
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_FROM_EMAIL=hello@jurisai.fr
MAILJET_FROM_NAME=JurisIA

# ---- YOUSIGN (Signature électronique) ----
YOUSIGN_API_KEY=            # Requis uniquement pour le plan Pro+
YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3  # Prod: https://api.yousign.app/v3

# ---- PAPPERS (Info entreprises SIREN) ----
PAPPERS_API_KEY=            # https://www.pappers.fr/api

# ---- SENTRY (Monitoring erreurs) ----
SENTRY_DSN=                 # https://...@sentry.io/...
SENTRY_ENVIRONMENT=development

# ---- POSTHOG (Product Analytics) ----
POSTHOG_API_KEY=            # phc_...
POSTHOG_HOST=https://eu.posthog.com

# ---- CELERY (Queue de tâches asynchrones) ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_MAX_RETRIES=3
CELERY_RETRY_DELAY=60       # secondes

# ---- RATE LIMITING ----
RATE_LIMIT_PER_MINUTE=60    # Requêtes par minute par IP
RATE_LIMIT_AUTH_PER_MINUTE=10  # Tentatives auth par minute (strict)

# ---- QUOTAS PAR PLAN ----
QUOTA_FREE_DOCUMENTS=3
QUOTA_STARTER_DOCUMENTS_PER_MONTH=20
QUOTA_STARTER_QUESTIONS_PER_MONTH=50
QUOTA_PRO_DOCUMENTS_PER_MONTH=9999   # "Illimité"
QUOTA_PRO_QUESTIONS_PER_MONTH=9999

# ---- LÉGIFRANCE API (Sources légales) ----
LEGIFRANCE_CLIENT_ID=       # https://developer.aife.economie.gouv.fr/
LEGIFRANCE_CLIENT_SECRET=

# ---- NEXT.JS (Frontend — variables publiques, préfixées NEXT_PUBLIC_) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # pk_test_... en dev
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
NEXT_PUBLIC_CRISP_WEBSITE_ID=       # Support chat
NEXT_PUBLIC_SENTRY_DSN=
